generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String            @id @default(uuid())
  name        String
  lastName    String            @map("last_name")
  username    String            @unique
  email       String            @unique
  password    String
  role        Role              @default(PLAYER)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  sheets      PokemonSheet[]    @relation("UserSheets")
  permissions SheetPermission[]

  @@map("users")
}

model NpcGroup {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  npcs        NpcTrainer[]
}

model NpcTrainer {
  id        String         @id @default(uuid())
  name      String
  title     String?
  notes     String?
  imageUrl  String?
  groupId   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  group     NpcGroup?      @relation(fields: [groupId], references: [id])
  sheets    PokemonSheet[] @relation("NpcSheets")
}

model PokemonSpecies {
  id         String        @id @default(uuid())
  name       String        @unique
  pokedexId  Int           @unique
  height     Float?
  weight     Float?
  createdAt  DateTime      @default(now())
  rarity     Int           @default(1)
  rationBase Int           @default(1)
  forms      PokemonForm[]
}

model PokemonForm {
  id           String         @id @default(uuid())
  speciesId    String
  name         String         @default("base")
  spriteUrl    String
  hp           Int
  attack       Int
  defense      Int
  spAttack     Int
  spDefense    Int
  speed        Int
  type1        String
  type2        String?
  createdAt    DateTime       @default(now())
  dig          Int            @default(0)
  dive         Int            @default(0)
  fly          Int            @default(0)
  intelligence Int            @default(0)
  jump         Int            @default(0)
  run          Int            @default(0)
  strength     Int            @default(0)
  swim         Int            @default(0)
  species      PokemonSpecies @relation(fields: [speciesId], references: [id])
  sheets       PokemonSheet[]

  @@unique([speciesId, name])
}

model Nature {
  id           String         @id @default(uuid())
  name         String         @unique
  increaseStat Stat
  decreaseStat Stat
  createdAt    DateTime       @default(now())
  sheets       PokemonSheet[]
}

model PokemonSheet {

  id             String   @id @default(uuid())
  nickname       String?
  customImageUrl String?
  notes          String?

  formId     String
  form       PokemonForm @relation(fields: [formId], references: [id])

  natureId   String?
  nature     Nature?     @relation(fields: [natureId], references: [id])

  ownerUserId String?
  ownerUser   User?       @relation("UserSheets", fields: [ownerUserId], references: [id])

  ownerNpcId  String?
  ownerNpc    NpcTrainer? @relation("NpcSheets", fields: [ownerNpcId], references: [id])

  permissions SheetPermission[]
  moves       PokemonSheetMove[]
  conditions  PokemonSheetCondition[]

  level Int @default(1)
  xp    Int @default(0)

  gender        Gender?
  abilityName   String?
  heldItemName  String?
  isShiny       Boolean @default(false)

  currentHp   Int?
  damageTaken Int @default(0)

  hpLevelPoints Int @default(0)
  hpVita        Int @default(0)
  hpTemp        Int @default(0)

  atkLevelPoints Int @default(0)
  atkVita        Int @default(0)
  atkTemp        Int @default(0)

  defLevelPoints Int @default(0)
  defVita        Int @default(0)
  defTemp        Int @default(0)

  spAtkLevelPoints Int @default(0)
  spAtkVita        Int @default(0)
  spAtkTemp        Int @default(0)

  spDefLevelPoints Int @default(0)
  spDefVita        Int @default(0)
  spDefTemp        Int @default(0)

  speedLevelPoints Int @default(0)
  speedVita        Int @default(0)
  speedTemp        Int @default(0)

  atkStage    Int @default(0)
  defStage    Int @default(0)
  spAtkStage  Int @default(0)
  spDefStage  Int @default(0)
  speedStage  Int @default(0)

  accuracyStage Int @default(0)
  evasionStage  Int @default(0)
  critStage     Int @default(1) 
  antiCritStage Int @default(1)

  canDynamax    Boolean @default(true)
  canGigantamax Boolean @default(false)

  loyalty     Int @default(0)
  training    Int @default(0)
  affection   Int @default(0)
  affectionXp Int @default(0)
  otherSkills String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PokemonSheetMove {
  id        String       @id @default(uuid())
  sheetId   String
  slot      Int
  moveName  String
  isSpecial Boolean      @default(false)
  createdAt DateTime     @default(now())
  sheet     PokemonSheet @relation(fields: [sheetId], references: [id])

  @@unique([sheetId, slot])
}

model PokemonSheetCondition {
  id         String        @id @default(uuid())
  sheetId    String
  type       ConditionType
  persistent Boolean       @default(true)
  createdAt  DateTime      @default(now())
  sheet      PokemonSheet  @relation(fields: [sheetId], references: [id])
}

model SheetPermission {
  id        String       @id @default(uuid())
  sheetId   String
  userId    String
  canEdit   Boolean      @default(false)
  createdAt DateTime     @default(now())
  sheet     PokemonSheet @relation(fields: [sheetId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([sheetId, userId])
}

enum Role {
  ADMIN
  PLAYER
}

enum Gender {
  MALE
  FEMALE
  GENDERLESS
}

enum Stat {
  HP
  ATTACK
  DEFENSE
  SP_ATTACK
  SP_DEFENSE
  SPEED
}

enum ConditionType {
  BURN
  POISON
  BAD_POISON
  PARALYSIS
  SLEEP
  FREEZE
  CONFUSION
  FLINCH
  CURSE
  TRAPPED
}
